# ====================================================================
# SMART AI CLIPPER - GITHUB IGNORE RULES
# ====================================================================

# 1. Python Environment & Cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
pip-log.txt
pip-delete-this-directory.txt

# 2. Storage & Media Files (Mencegah file video menyumbat GitHub)
storage/raw_videos/*
storage/audio_tracks/*
storage/output_shorts/*

# Pengecualian: Izinkan file .gitkeep tetap ter-upload agar struktur folder tidak hilang
!storage/raw_videos/.gitkeep
!storage/audio_tracks/.gitkeep
!storage/output_shorts/.gitkeep
!storage/.gitkeep

# 3. Kredensial & API Keys (SANGAT RAHASIA - Jangan Sampai Bocor!)
client_secret.json
config/token.json
config/settings.json
*.env

# 4. OS & Editor Trash
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp